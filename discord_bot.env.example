# Copy this to .env and fill in your values.
# Run: python claude_code_discord_bot.py

# --- Required ---
DISCORD_TOKEN=your-bot-token-here

# Your Discord user ID (right-click yourself → Copy ID, with Developer Mode on)
ALLOWED_USER_IDS=111111111111111111

# --- Optional ---

# Restrict the bot to specific channels (comma-separated IDs). Recommended.
# ALLOWED_CHANNEL_IDS=222222222222222222,333333333333333333

# Projects as JSON: {"alias": "/absolute/path/to/repo"}
# Use forward slashes on Windows too, or double-backslashes.
PROJECTS={"maestro":"C:/Users/avish/OneDrive/Desktop/maestro"}
DEFAULT_PROJECT=maestro

# Full path to the claude binary if it's not on PATH
# CLAUDE_BIN=C:/Users/avish/AppData/Roaming/npm/claude.cmd

# "acceptEdits" approves file writes automatically. Change to "default" to require approval.
# PERMISSION_MODE=acceptEdits

# Comma-separated list of tools to auto-approve
# ALLOWED_TOOLS=Read,Edit,Write,Bash,Glob,Grep,TodoWrite

# Hard timeout per run in seconds (default 1800 = 30 min)
# RUN_TIMEOUT=1800

# Max number of `claude` processes running at once, across all channels/projects.
# MAX_CONCURRENT=2

# Git safety net: when set to 1, each fresh session's edits are isolated on a new
# `anton/<timestamp>-<uuid>` branch (skipped if the tree is already dirty). Then
# !diff reviews the changes and !revert throws them away. Off by default; runs
# edit the working tree in place. !diff and !revert still work without it.
# AUTO_BRANCH=0

# Attachments: files dropped on a !cc/!plan message are saved here and their
# paths passed to Claude. Defaults to a temp dir (no repo pollution). Set this to
# a path inside a project if your Claude setup can't read outside the repo.
# UPLOAD_DIR=/tmp/anton-uploads
# Per-attachment size cap (MB) and per-message count cap.
# MAX_ATTACH_MB=25
# MAX_ATTACH_COUNT=10

# Where per-channel state (project/session/model/usage) is persisted so it
# survives restarts. Defaults to anton.db next to this script.
# ANTON_DB=anton.db
